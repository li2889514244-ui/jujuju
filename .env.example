# ===========================================
# MatrixFlow ERP environment variables
# Copy this file to .env and fill in real values.
# ===========================================

# ---------- Application ----------
APP_NAME=MatrixFlow ERP
APP_PORT=3000
APP_ENV=development
APP_DEBUG=true
APP_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS
CORS_ORIGIN=https://ddddkiii.com

# ---------- MCP remote server ----------
# Comma-separated bearer tokens. Format: clientId:token,clientId2:token2
# Generate token with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MCP_API_KEYS=
MCP_ALLOWED_ORIGINS=
MCP_MAX_ROWS=500
MCP_MAX_RANGE_DAYS=366

# ---------- Feishu / Lark notifications ----------
# Incoming bot webhook. Alias LARK_WEBHOOK_URL is also supported.
FEISHU_WEBHOOK_URL=
# Optional bot signing secret. Alias LARK_WEBHOOK_SECRET is also supported.
FEISHU_WEBHOOK_SECRET=
FEISHU_NOTIFY_ENABLED=true
# Empty means all notification types. Example: PUBLISH_FAILED,CREDENTIAL_EXPIRED,SYSTEM
FEISHU_NOTIFY_TYPES=

# ---------- PostgreSQL ----------
DATABASE_URL=postgresql://matrixflow:CHANGE_ME_USE_STRONG_PASSWORD@localhost:5432/matrixflow_erp
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=matrixflow
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
# Use a strong password with 16+ chars, mixed case, numbers, and symbols.
DB_NAME=matrixflow_erp
DB_SYNCHRONIZE=false
DB_SSL=false

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
REDIS_DB=0

# ---------- JWT ----------
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_REFRESH_EXPIRES_IN=30d

# ---------- Frontend (Vite) ----------
# These are embedded at build time. Set them in CI/CD or Cloudflare Pages dashboard for hosted builds.
VITE_API_BASE_URL=https://ddddkiii.com/api/v1
VITE_WS_URL=wss://ddddkiii.com/ws

# ---------- Uploads ----------
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=50mb

# ---------- Email (optional) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------- Logging ----------
LOG_LEVEL=debug
LOG_DIR=./logs

# ---------- Cloudflare Pages ----------
# Set these in GitHub Actions secrets, NOT here.
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
