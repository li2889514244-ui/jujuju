# ===========================================
# MatrixFlow ERP 环境变量配置
# 复制此文件为 .env 并填入实际值
# ===========================================

# ---------- 应用 ----------
APP_NAME=MatrixFlow ERP
APP_PORT=3000
APP_ENV=development
APP_DEBUG=true
APP_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# ---------- 数据库 (PostgreSQL) ----------
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=matrixflow
DB_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
DB_NAME=matrixflow_erp
DB_SYNCHRONIZE=false
DB_SSL=false

# ---------- Redis ----------
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_USE_STRONG_PASSWORD
REDIS_DB=0

# ---------- JWT ----------
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
JWT_EXPIRES_IN=7d
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_64_CHARS
JWT_REFRESH_EXPIRES_IN=30d

# ---------- 前端 (Vite) ----------
# These are embedded at build time — set in CI/CD or Cloudflare Pages dashboard
VITE_API_BASE_URL=https://api.matrixflow.io/api
VITE_WS_URL=wss://api.matrixflow.io

# ---------- 浏览器引擎 ----------
BROWSER_ENGINE_PORT=3001
BROWSER_HEADLESS=true
BROWSER_MAX_CONCURRENT=5
BROWSER_PROXY_ENABLED=false
BROWSER_PROXY_URL=

# ---------- 文件上传 ----------
UPLOAD_DIR=./uploads
UPLOAD_MAX_SIZE=50mb

# ---------- 邮件 (可选) ----------
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# ---------- 日志 ----------
LOG_LEVEL=debug
LOG_DIR=./logs

# ---------- Cloudflare Pages ----------
# Set these in GitHub Actions secrets, NOT here
# CLOUDFLARE_API_TOKEN=
# CLOUDFLARE_ACCOUNT_ID=
