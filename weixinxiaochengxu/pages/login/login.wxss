/* pages/login/login.wxss */
.login-wrap {
  min-height: 100vh;
  padding: 120rpx 60rpx;
  box-sizing: border-box;
  display: flex;
  flex-direction: column;
}

.brand {
  text-align: center;
  margin-bottom: 80rpx;
}

.logo {
  width: 120rpx;
  height: 120rpx;
  line-height: 120rpx;
  margin: 0 auto 24rpx;
  border-radius: 28rpx;
  background: linear-gradient(135deg, #5b8cff, #8b5bff);
  color: #fff;
  font-size: 44rpx;
  font-weight: 700;
}

.brand-name {
  font-size: 40rpx;
  font-weight: 600;
  color: #fff;
}

.brand-sub {
  font-size: 26rpx;
  color: #8b90a8;
  margin-top: 8rpx;
}

.field {
  margin-bottom: 32rpx;
}

.label {
  display: block;
  font-size: 26rpx;
  color: #8b90a8;
  margin-bottom: 12rpx;
}

.input {
  background: #151826;
  border: 1rpx solid rgba(255, 255, 255, 0.06);
  border-radius: 14rpx;
  padding: 24rpx;
  color: #fff;
  font-size: 30rpx;
}

.ph {
  color: #4b4f63;
}

.btn-login {
  margin-top: 20rpx;
  background: linear-gradient(135deg, #5b8cff, #8b5bff);
  color: #fff;
  border-radius: 14rpx;
  font-size: 32rpx;
  font-weight: 600;
  padding: 20rpx 0;
}

.btn-login::after {
  border: none;
}

.tip {
  text-align: center;
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 40rpx;
}
