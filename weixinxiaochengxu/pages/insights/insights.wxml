<!-- pages/insights/insights.wxml -->
<view class="container">
  <view class="page-head">
    <text class="title">数据洞察</text>
  </view>

  <block wx:if="{{loading && !platformStats.length}}">
    <view class="loading">加载中...</view>
  </block>

  <block wx:else>
    <view class="card">
      <view class="card-title">各平台统计</view>
      <view class="eff-row eff-head">
        <text class="c1">平台</text>
        <text class="c2">账号</text>
        <text class="c3">粉丝</text>
        <text class="c4">播放</text>
      </view>
      <view class="eff-row" wx:for="{{platformStats}}" wx:key="platform">
        <text class="c1">{{item.platform}}</text>
        <text class="c2">{{item.accounts}}</text>
        <text class="c3">{{item.followers}}</text>
        <text class="c4">{{item.views}}</text>
      </view>
      <view wx:if="{{!platformStats.length}}" class="empty">暂无数据</view>
    </view>

    <view class="card">
      <view class="card-title">近14天粉丝趋势</view>
      <view class="eff-row eff-head">
        <text class="c1">日期</text>
        <text class="c2">粉丝增量</text>
      </view>
      <view class="eff-row" wx:for="{{followerTrend}}" wx:key="date">
        <text class="c1">{{item.date}}</text>
        <text class="c2">{{item.value}}</text>
      </view>
      <view wx:if="{{!followerTrend.length}}" class="empty">暂无数据</view>
    </view>
  </block>
</view>
