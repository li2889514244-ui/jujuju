/* pages/insights/insights.wxss */
.page-head {
  margin-bottom: 28rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.eff-row {
  display: flex;
  align-items: center;
  padding: 18rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.04);
  font-size: 26rpx;
}

.eff-row:last-child {
  border-bottom: none;
}

.eff-head {
  color: #6b7280;
  font-size: 24rpx;
}

.c1 { flex: 2; color: #c7cbe0; }
.c2 { flex: 1; text-align: center; color: #e6e8f0; }
.c3 { flex: 1; text-align: center; color: #e6e8f0; }
.c4 { flex: 1; text-align: center; color: #e6e8f0; }
