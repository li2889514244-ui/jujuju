/* pages/accounts/accounts.wxss */
.page-head {
  margin-bottom: 28rpx;
}

.title {
  font-size: 40rpx;
  font-weight: 700;
  color: #fff;
  display: block;
}

.subtitle {
  font-size: 24rpx;
  color: #5b8cff;
}

.acc-card {
  display: flex;
  align-items: center;
  background: #151826;
  border-radius: 16rpx;
  padding: 24rpx;
  margin-bottom: 16rpx;
  border: 1rpx solid rgba(255, 255, 255, 0.04);
}

.avatar {
  width: 88rpx;
  height: 88rpx;
  border-radius: 50%;
  background: #1f2233;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.acc-info {
  flex: 1;
  overflow: hidden;
}

.acc-name {
  font-size: 30rpx;
  color: #fff;
  font-weight: 500;
  margin-bottom: 10rpx;
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.acc-plat {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.acc-status {
  font-size: 22rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255, 255, 255, 0.06);
  color: #8b90a8;
}

.status-valid {
  color: #4ade80;
  background: rgba(74, 222, 128, 0.12);
}

.status-expired {
  color: #f87171;
  background: rgba(248, 113, 113, 0.12);
}

.acc-fans {
  text-align: right;
  flex-shrink: 0;
}

.fans-num {
  font-size: 34rpx;
  font-weight: 600;
  color: #fff;
}

.fans-label {
  font-size: 22rpx;
  color: #6b7280;
}
