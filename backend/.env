# MatrixFlow - SQLite Production
PORT=3000
NODE_ENV=production

# SQLite (轻量化，无需外部进程)
DATABASE_URL=file:./data/matrixflow.db

# JWT
JWT_SECRET=matrixflow-jwt-secret-key-2026-production
JWT_ACCESS_EXPIRES=7d
JWT_REFRESH_SECRET=matrixflow-refresh-secret-key-2026
JWT_REFRESH_EXPIRES=30d

# Cookie 加密
COOKIE_ENCRYPTION_KEY=matrixflow-cookie-encryption-key-32chars!
TOKEN_ENCRYPTION_KEY=matrixflow-token-encryption-key-32chars!!

# CORS
CORS_ORIGIN=https://jujuju-28b.pages.dev,https://ddddkiii.com
