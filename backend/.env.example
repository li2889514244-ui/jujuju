# MatrixFlow ERP - 环境变量配置

# 应用
PORT=3000
NODE_ENV=development

# 数据库 (PostgreSQL)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matrixflow

# JWT (REQUIRED - 至少32字符)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_SECRET=CHANGE_ME_GENERATE_RANDOM_32_CHARS
JWT_REFRESH_EXPIRES=7d

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Cookie 加密密钥 (REQUIRED - 至少32字符)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# OAuth Token 加密密钥 (REQUIRED - 至少32字符)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
TOKEN_ENCRYPTION_KEY=CHANGE_ME_GENERATE_RANDOM_32_CHARS

# CORS — 逗号分隔多域名，或 '*' 允许所有（仅开发环境）
# Production: CORS_ORIGIN=https://jujuju.pages.dev
CORS_ORIGIN=http://localhost:3000,http://localhost:5173

# 平台 OAuth 配置
DOUYIN_CLIENT_ID=
DOUYIN_CLIENT_SECRET=
DOUYIN_CALLBACK_URL=http://localhost:3000/api/platforms/oauth/callback/douyin
KUAISHOU_CLIENT_ID=
KUAISHOU_CLIENT_SECRET=
KUAISHOU_CALLBACK_URL=http://localhost:3000/api/platforms/oauth/callback/kuaishou
XIAOHONGSHU_CLIENT_ID=
XIAOHONGSHU_CLIENT_SECRET=
XIAOHONGSHU_CALLBACK_URL=http://localhost:3000/api/platforms/oauth/callback/xiaohongshu
WECHAT_VIDEO_CLIENT_ID=
WECHAT_VIDEO_CLIENT_SECRET=
WECHAT_VIDEO_CALLBACK_URL=http://localhost:3000/api/platforms/oauth/callback/shipinhao
BILIBILI_CLIENT_ID=
BILIBILI_CLIENT_SECRET=
BILIBILI_CALLBACK_URL=http://localhost:3000/api/platforms/oauth/callback/bilibili
WEIBO_CLIENT_ID=
WEIBO_CLIENT_SECRET=
WEIBO_CALLBACK_URL=http://localhost:3000/api/platforms/oauth/callback/weibo
