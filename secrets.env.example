# ============================================================
# MatrixFlow 生产密钥模板
# 使用方法: cp secrets.env.example secrets.env → 填入实际值
# ⚠️ secrets.env 已加入 .gitignore，禁止提交
# ============================================================

# 阿里云 AK
ALI_ACCESS_KEY_ID=CHANGE_ME
ALI_ACCESS_KEY_SECRET=CHANGE_ME
ALI_REGION=cn-guangzhou
ECS_INSTANCE_ID=CHANGE_ME
ECS_HOST=CHANGE_ME

# SSH
ECS_SSH_USER=root
ECS_SSH_PASSWORD=CHANGE_ME

# 数据库
DB_PASSWORD=CHANGE_ME
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=matrixflow
DB_USER=postgres

# Redis
REDIS_PASSWORD=CHANGE_ME
REDIS_HOST=127.0.0.1
REDIS_PORT=6379

# JWT
JWT_SECRET=CHANGE_ME
JWT_REFRESH_SECRET=CHANGE_ME

# 加密密钥
COOKIE_ENCRYPTION_KEY=CHANGE_ME
TOKEN_ENCRYPTION_KEY=CHANGE_ME

# 管理员
ADMIN_PASSWORD=CHANGE_ME
ADMIN_EMAIL=CHANGE_ME
